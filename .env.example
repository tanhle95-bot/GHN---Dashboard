# ===== Authentication =====
# Secret key for signing session tokens (use: openssl rand -hex 32)
JWT_SECRET=change-this-to-a-random-secret-string

# Users list in format username:salt:sha256hash
# Generate hash: python3 -c "import hashlib; print(hashlib.sha256(b'YOUR_SALT' + b'YOUR_PASSWORD').hexdigest())"
USERS=admin:ghn2024salt:your_hashed_password_here

# ===== Data Source =====
# Allowed Google Sheet ID (prevents SSRF)
ALLOWED_SHEET_ID=1Kjqwt6MIghCzfCSifVrpIpVHbC0o77lxMVVFlCZ26xY

# Allowed origins for CSRF protection (comma-separated)
ALLOWED_ORIGINS=https://ghn-dashboard-j6vc.vercel.app

# ===== Telegram Bot =====
# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# Your personal chat ID (Quản lý nhận báo cáo)
TELEGRAM_MANAGER_CHAT_ID=-100123456789

# Contacts by warehouse (JSON format)
# Keys = tên viết tắt kho, Values = object với chat_id cho từng vai trò
TELEGRAM_CONTACTS={"Long Biên":{"lead":"123","nvpttt":"456","am":"789"},"Bắc Từ Liêm":{"lead":"111","nvpttt":"222","am":"333"}}

# ===== Cron Jobs =====
# Secret to protect cron endpoints from unauthorized access
CRON_SECRET=your-random-cron-secret

# ===== Thresholds =====
# Ngưỡng %GTC cảnh báo (mặc định: 65%)
GTC_THRESHOLD=65

# Mục tiêu %GTC (mặc định: 75%)
GTC_TARGET=75

# Ngưỡng tỷ lệ gán chuyến (mặc định: 70%)
ASSIGNMENT_THRESHOLD=70
